{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "plan-opus": {
      "description": "Only do planning and output plans for others to follow",
      "mode": "primary",
      "model": "github-copilot/gpt-5.4",
      "reasoningEffort": "high",
      "temperature": 0.2,
      "color": "warning",
      "prompt": "Only do planning and output the plan that other people or agent can execute. Plan does not need to be super-detailed as source code level, but must contain clear architecture and must be clear enough for others to follow."
    },
    "build-opus": {
      "description": "Build and modify code with full tool access",
      "mode": "primary",
      "model": "github-copilot/gpt-5.4",
      "reasoningEffort": "high",
      "temperature": 0.5,
      "color": "info"
    }
  },
  "mcp": {
    "gateway": {
      "enabled": true,
      "type": "remote",
      "url": "http://host.docker.internal:8080/mcp"
    }
  }
}

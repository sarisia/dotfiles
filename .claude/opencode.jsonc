{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "plan-opus": {
      "description": "Only do planning and output detailed execution plans for others to follow",
      "mode": "primary",
      "model": "github-copilot/claude-opus-4.6",
      "temperature": 0.2,
      "color": "warning",
      "prompt": "only do planning and output the detailed plan that other people or agent can execute."
    },
    "build-opus": {
      "description": "Build and modify code with full tool access",
      "mode": "primary",
      "model": "github-copilot/claude-sonnet-4.6",
      "temperature": 0.5,
      "color": "info"
    }
  },
  "mcp": {
    "gateway": {
      "enabled": true,
      "type": "remote",
      "url": "http://host.docker.internal:8080/mcp"
    }
  }
}
